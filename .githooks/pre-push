#!/usr/bin/env bash
set -euo pipefail

current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [[ "$current_branch" == local/* ]]; then
  echo "[BLOCKED] Refusing push from local/private branch: $current_branch"
  echo "Use: git checkout main && cherry-pick only public commits."
  exit 1
fi

# Private docs and local tooling paths that must never be tracked on the public branch tip
forbidden_regex='^(CLAUDE\.md|TODO\.md|docs/TODO_WORKFLOW\.md|docs/TODO_DONE_LOG\.md|docs/CODE_REVIEW_.*\.md|docs/TECH_DEBT\.md|docs/MOBILE_LAYOUT_AUDIT_.*\.md|docs/plans/|\.private/|\.claude/|\.worktrees/)'

if git ls-tree -r --name-only HEAD | grep -Eq "$forbidden_regex"; then
  echo "[BLOCKED] Private documentation paths are tracked on this branch tip."
  echo "Remove private files from tracking before pushing."
  git ls-tree -r --name-only HEAD | grep -E "$forbidden_regex" || true
  exit 1
fi

# Enforce commit prefix policy for pushes to main.
# - Human commits on main must start with `public:`
# - Bot commits are allowed only when they start with `data:`
zero_sha='0000000000000000000000000000000000000000'
main_push_commits=()
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_ref" == "refs/heads/main" ]] || continue
  if [[ "$local_sha" == "$zero_sha" ]]; then
    continue
  fi
  if [[ "$remote_sha" == "$zero_sha" ]]; then
    range="$local_sha"
  else
    range="${remote_sha}..${local_sha}"
  fi
  while read -r sha; do
    found=false
    for existing in "${main_push_commits[@]}"; do
      if [[ "$existing" == "$sha" ]]; then
        found=true
        break
      fi
    done
    if [[ "$found" == false ]]; then
      main_push_commits+=("$sha")
    fi
  done < <(git rev-list --no-merges "$range")
done

if [[ ${#main_push_commits[@]} -gt 0 ]]; then
  for sha in "${main_push_commits[@]}"; do
    author="$(git show -s --format=%an "$sha")"
    subject="$(git show -s --format=%s "$sha")"
    if [[ "$author" == "github-actions[bot]" ]]; then
      if [[ "$subject" != data:* ]]; then
        echo "[BLOCKED] Bot commit on main must start with 'data:'"
        echo "  $sha $subject"
        exit 1
      fi
      continue
    fi
    if [[ "$subject" != public:* ]]; then
      echo "[BLOCKED] Human commit on main must start with 'public:'"
      echo "  $sha $subject"
      exit 1
    fi
  done
fi

# Block embedded repositories (gitlinks/submodules) in public history.
if git ls-tree -r HEAD | awk '$1=="160000"{print $4}' | grep -q .; then
  echo "[BLOCKED] Embedded git repositories (gitlinks) detected on branch tip."
  echo "Remove them from index before pushing:"
  git ls-tree -r HEAD | awk '$1=="160000"{print $4}'
  exit 1
fi

exit 0
