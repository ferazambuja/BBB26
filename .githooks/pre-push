#!/usr/bin/env bash
set -euo pipefail

current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [[ "$current_branch" == local/* ]]; then
  echo "[BLOCKED] Refusing push while checked out on local-only branch: $current_branch"
  echo "Switch back to main or a reviewed feature branch before pushing."
  exit 1
fi

# Private docs and local tooling paths that must never appear in public history
forbidden_regex='^(CLAUDE\.md|TODO\.md|docs/TODO_WORKFLOW\.md|docs/TODO_DONE_LOG\.md|docs/CODE_REVIEW_.*\.md|docs/TECH_DEBT\.md|docs/MOBILE_LAYOUT_AUDIT_.*\.md|docs/plans/|docs/superpowers/|\.private/|\.claude/|\.worktrees/)'

if git ls-tree -r --name-only HEAD | grep -Eq "$forbidden_regex"; then
  echo "[BLOCKED] Private documentation paths are tracked on this branch tip."
  echo "Remove private files from tracking before pushing."
  git ls-tree -r --name-only HEAD | grep -E "$forbidden_regex" || true
  exit 1
fi

# Enforce denylist and bot-prefix policy on pushed commits.
# - Human commits on main may use normal descriptive subjects
# - Bot commits are allowed only when they start with `data:`
zero_sha='0000000000000000000000000000000000000000'
pushed_commits=()
main_push_commits=()
while read -r local_ref local_sha remote_ref remote_sha; do
  is_push_to_main=false
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    is_push_to_main=true
  fi

  if [[ "$local_ref" == refs/heads/local/* ]]; then
    echo "[BLOCKED] Refusing push of local-only branch: ${local_ref#refs/heads/}"
    echo "Use main for normal published work, or finish reviewing archived local history first."
    exit 1
  fi
  if [[ "$local_sha" == "$zero_sha" ]]; then
    continue
  fi
  branch_name="${local_ref#refs/heads/}"
  if [[ "$remote_sha" == "$zero_sha" ]]; then
    range="$local_sha"
  else
    range="${remote_sha}..${local_sha}"
  fi

  # If remote_sha is not present locally yet, fall back to upstream diff (or
  # the local tip as a last resort) to avoid invalid revision errors.
  if ! git rev-list "$range" >/dev/null 2>&1; then
    if upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name "${branch_name}@{u}" 2>/dev/null)"; then
      range="${upstream_ref}..${local_sha}"
    else
      range="$local_sha"
    fi
  fi

  while read -r sha; do
    [[ -n "$sha" ]] || continue
    found=false
    for existing in "${pushed_commits[@]}"; do
      if [[ "$existing" == "$sha" ]]; then
        found=true
        break
      fi
    done
    if [[ "$found" == false ]]; then
      pushed_commits+=("$sha")
    fi

    [[ "$is_push_to_main" == true ]] || continue
    found=false
    for existing in "${main_push_commits[@]}"; do
      if [[ "$existing" == "$sha" ]]; then
        found=true
        break
      fi
    done
    if [[ "$found" == false ]]; then
      main_push_commits+=("$sha")
    fi
  done < <(git rev-list "$range" 2>/dev/null || true)
done

if [[ ${#pushed_commits[@]} -gt 0 ]]; then
  for sha in "${pushed_commits[@]}"; do
    if git ls-tree -r --name-only "$sha" | grep -Eq "$forbidden_regex"; then
      echo "[BLOCKED] Private documentation paths appear in commit history being pushed."
      echo "  commit: $sha $(git show -s --format=%s "$sha")"
      git ls-tree -r --name-only "$sha" | grep -E "$forbidden_regex" || true
      exit 1
    fi
  done
fi

if [[ ${#main_push_commits[@]} -gt 0 ]]; then
  for sha in "${main_push_commits[@]}"; do
    author="$(git show -s --format=%an "$sha")"
    subject="$(git show -s --format=%s "$sha")"
    if [[ "$author" == "github-actions[bot]" ]]; then
      if [[ "$subject" != data:* ]]; then
        echo "[BLOCKED] Bot commit on main must start with 'data:'"
        echo "  $sha $subject"
        exit 1
      fi
    fi
  done
fi

# Block embedded repositories (gitlinks/submodules) in public history.
if git ls-tree -r HEAD | awk '$1=="160000"{print $4}' | grep -q .; then
  echo "[BLOCKED] Embedded git repositories (gitlinks) detected on branch tip."
  echo "Remove them from index before pushing:"
  git ls-tree -r HEAD | awk '$1=="160000"{print $4}'
  exit 1
fi

exit 0
